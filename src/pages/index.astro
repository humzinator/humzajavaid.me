---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
<main>
  <h1>🧑‍💻 Hey, it's Humza Arshed</h1>
  <p>
    Welcome to the corner of the internet run by <strong>Humza Arshed Javaid</strong> — Maryland native, cloud architect, and occasional roti enthusiast. (Yes, that's where "Roti Mason" comes from: a bit more than curry.)
  </p>
  <p>
    Grew up in the Leonardtown / Mechanicsville area, studied at UMBC (University of Maryland Baltimore County), and cut my teeth in cloud solutions and emerging tech — including time at Smartronix (now part of SMX) building systems that actually matter.
  </p>
  <p>
    These days I'm at <a href="https://www.linkedin.com/in/humzajavaid">ElasticBin</a> as a Founding Architect, tinkering with scalable infrastructure and keeping things running smoothly. When I'm not in the cloud, I'm back home, posting low-key takes on X (@humzinator), moving furniture, or reminding myself why family ties run deep (shoutout to my dad, Arshed Javaid — engineer, Parraid co-founder, and all-around legend).
  </p>
  <p>Quick ways to poke around here:</p>
  <ul>
    <li>Scroll my latest thoughts on <a href="https://x.com/humzinator">X</a> — mostly casual, sometimes spicy</li>
    <li>Check my LinkedIn for the professional timeline</li>
    <li>Hit me up if you're into cloud architecture, South Asian food debates, or just vibes</li>
  </ul>
  <p>
    Keep it real. If you're building something cool or just passing through, say hi. 🚀
  </p>
	<div style="display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; align-items: center; margin: 20px 0;">
	  <!-- Buy Me a Coffee button -->
	  <script type="text/javascript"
	    src="https://cdnjs.buymeacoffee.com/1.0.0/button.prod.min.js"
	    data-name="bmc-button"
	    data-slug="humzjavz"
	    data-color="#FFDD00"
	    data-emoji="☕"
	    data-font="Cookie"
	    data-text="Buy me a coffee"
	    data-outline-color="#000000"
	    data-font-color="#000000"
	    data-coffee-color="#ffffff">
	  </script>
	
	  <!-- Retool Dashboard button -->
	  <a href="https://humzjav.retool.com/" target="_blank" rel="noopener noreferrer" style="text-decoration: none;">
	    <button style="
	      background: linear-gradient(135deg, #0066cc, #004080);
	      color: white;
	      padding: 18px 32px;
	      font-size: 18px;
	      font-weight: bold;
	      border: none;
	      border-radius: 8px;
	      cursor: pointer;
	      box-shadow: 0 6px 12px rgba(0, 102, 204, 0.3);
	      transition: transform 0.15s, box-shadow 0.15s;
	      min-width: 220px;
	    " 
	    onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 10px 20px rgba(0,102,204,0.4)'"
	    onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 6px 12px rgba(0,102,204,0.3)'">
	      Launch Retool Dashboard
	    </button>
  </a>
</div>
</main>
		<Footer />
	</body>
</html>
